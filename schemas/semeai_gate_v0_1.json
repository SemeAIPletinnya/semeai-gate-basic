{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.semeai/schema/semeai_gate_v0_1.json",
  "title": "SemeAI Gate Business Contract v0.1",
  "description": "Versioned local contract for a host product to submit an AI answer for release control.",
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_message",
        "ai_answer",
        "business_data",
        "business_rules",
        "business_risk"
      ],
      "properties": {
        "user_message": { "type": "string", "minLength": 1 },
        "ai_answer": { "type": "string", "minLength": 1 },
        "business_data": {
          "oneOf": [
            { "type": "object" },
            { "type": "array" }
          ]
        },
        "business_rules": { "type": "object" },
        "business_context": { "type": "object" },
        "hidden_context_marker": {
          "type": "string",
          "description": "Deterministic internal context hint. It is not a user-facing secret."
        },
        "expected_answer_scope": { "type": "string" },
        "business_risk": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object" }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "action",
        "internal_decision",
        "show_to_user",
        "reason",
        "business_risk",
        "context_integrity",
        "risk_details",
        "next_step",
        "audit_id",
        "audit_preserved"
      ],
      "properties": {
        "schema_version": { "const": "0.1" },
        "action": { "enum": ["SHOW", "REVIEW", "BLOCK"] },
        "internal_decision": { "enum": ["PROCEED", "NEEDS_REVIEW", "SILENCE"] },
        "show_to_user": { "type": "boolean" },
        "reason": { "type": "string" },
        "business_risk": { "type": "string" },
        "context_integrity": { "enum": ["ok", "warning", "failed"] },
        "risk_details": {
          "type": "array",
          "items": { "type": "string" }
        },
        "next_step": { "type": "string" },
        "audit_id": { "type": ["string", "null"] },
        "audit_preserved": { "type": "boolean" },
        "safe_fallback": { "type": ["string", "null"] },
        "technical_details": { "type": "object" }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "SHOW" } } },
          "then": {
            "properties": {
              "internal_decision": { "const": "PROCEED" },
              "show_to_user": { "const": true }
            }
          }
        },
        {
          "if": { "properties": { "action": { "enum": ["REVIEW", "BLOCK"] } } },
          "then": { "properties": { "show_to_user": { "const": false } } }
        }
      ]
    }
  }
}
