{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.semeai/schema/semeai_gate_basic_v0_1.json",
  "title": "SemeAI Gate Basic Contract v0.1",
  "$defs": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["user_message", "ai_answer", "business_data", "business_rules", "business_risk"],
      "properties": {
        "user_message": { "type": "string", "minLength": 1 },
        "ai_answer": { "type": "string", "minLength": 1 },
        "business_data": { "oneOf": [{ "type": "object" }, { "type": "array" }] },
        "business_rules": { "type": "object" },
        "business_context": { "type": "object" },
        "expected_answer_scope": { "type": "string" },
        "business_risk": { "type": "string", "minLength": 1 },
        "metadata": { "type": "object" }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "action",
        "internal_decision",
        "show_to_user",
        "reason",
        "business_risk",
        "context_integrity",
        "risk_details",
        "next_step",
        "audit_id",
        "audit_preserved"
      ],
      "properties": {
        "schema_version": { "const": "0.1" },
        "action": { "enum": ["SHOW", "REVIEW", "BLOCK"] },
        "internal_decision": { "enum": ["PROCEED", "NEEDS_REVIEW", "SILENCE"] },
        "show_to_user": { "type": "boolean" },
        "reason": { "type": "string" },
        "business_risk": { "type": "string" },
        "context_integrity": { "enum": ["ok", "warning", "failed"] },
        "risk_details": { "type": "array", "items": { "type": "string" } },
        "next_step": { "type": "string" },
        "audit_id": { "type": "string" },
        "audit_preserved": { "const": true },
        "safe_fallback": { "type": ["string", "null"] },
        "technical_details": { "type": "object" }
      }
    }
  }
}
